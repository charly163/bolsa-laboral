generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  POSTULANTE
  RECLUTADOR
  ADMIN
}

enum JobMode {
  PRESENCIAL
  HIBRIDO
  REMOTO
}

enum JobStatus {
  ACTIVA
  CERRADA
}

enum ApplicationStatus {
  RECIBIDA
  EN_REVISION
  ENTREVISTA
  RECHAZADA
  CONTRATADO
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(POSTULANTE)

  profile      Profile?
  jobsPosted   Job[]         @relation("RecruiterJobs")
  applications Application[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Profile {
  id     String  @id @default(cuid())
  bio    String?
  cvUrl  String?
  userId String  @unique
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  skills Skill[] @relation("ProfileSkills")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Skill {
  id   String @id @default(cuid())
  name String @unique

  profiles Profile[] @relation("ProfileSkills")
  jobs     Job[]     @relation("JobSkills")
}

model Job {
  id          String    @id @default(cuid())
  title       String
  description String
  company     String
  location    String?
  salaryRange String?
  mode        JobMode   @default(PRESENCIAL)
  status      JobStatus @default(ACTIVA)

  recruiterId String
  recruiter   User   @relation("RecruiterJobs", fields: [recruiterId], references: [id])

  skills       Skill[]       @relation("JobSkills")
  applications Application[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Application {
  id     String            @id @default(cuid())
  status ApplicationStatus @default(RECIBIDA)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  jobId String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, jobId])
}
