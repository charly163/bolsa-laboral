generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  POSTULANTE
  RECLUTADOR
  ADMIN
}

enum JobMode {
  PRESENCIAL
  HIBRIDO
  REMOTO
}

enum JobStatus {
  ACTIVA
  CERRADA
}

enum ApplicationStatus {
  RECIBIDA
  EN_REVISION
  INTERESADO
  FINALIZADO
}

// ─── Category (with subcategory support via parentId) ───

model Category {
  id        String     @id @default(cuid())
  name      String     @unique
  slug      String     @unique
  parentId  String?
  parent    Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children  Category[] @relation("SubCategories")

  profiles Profile[]
  jobs     Job[]

  createdAt DateTime @default(now())
}

// ─── User ───

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(POSTULANTE)
  phone         String?
  dni           String?
  verificadoCfp Boolean   @default(false)

  profile      Profile?
  jobsPosted   Job[]          @relation("RecruiterJobs")
  applications Application[]
  contactsFrom ContactLog[]   @relation("ContactFrom")
  contactsTo   ContactLog[]   @relation("ContactTo")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Profile ───

model Profile {
  id     String  @id @default(cuid())
  bio    String?
  cvUrl  String?
  userId String  @unique
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Category / trade
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])
  destacado  Boolean   @default(false)

  // Company fields (for RECLUTADOR profiles)
  companyName        String?
  cuit               String?
  address            String?
  website            String?
  companyDescription String?

  skills Skill[] @relation("ProfileSkills")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Skill ───

model Skill {
  id   String @id @default(cuid())
  name String @unique

  profiles Profile[] @relation("ProfileSkills")
  jobs     Job[]     @relation("JobSkills")
}

// ─── Job ───

model Job {
  id          String    @id @default(cuid())
  title       String
  description String
  company     String
  location    String?
  salaryRange String?
  mode        JobMode   @default(PRESENCIAL)
  status      JobStatus @default(ACTIVA)

  recruiterId String
  recruiter   User   @relation("RecruiterJobs", fields: [recruiterId], references: [id])

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  skills       Skill[]       @relation("JobSkills")
  applications Application[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Application ───

model Application {
  id             String            @id @default(cuid())
  status         ApplicationStatus @default(RECIBIDA)
  mensajeInicial String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  jobId String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, jobId])
}

// ─── ContactLog ───

model ContactLog {
  id         String  @id @default(cuid())
  fromUserId String
  fromUser   User    @relation("ContactFrom", fields: [fromUserId], references: [id])
  toUserId   String
  toUser     User    @relation("ContactTo", fields: [toUserId], references: [id])
  mensaje    String?

  createdAt DateTime @default(now())
}
